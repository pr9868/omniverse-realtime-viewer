# Copy to .env.local and fill in your values.

# NGC API key — required for downloading NVIDIA packages (ovrtx) during npm install.
# Get your key at: https://build.nvidia.com/
NGC_API_KEY=nvapi-your-key-here

# Server IP for the Vite dev-server proxy (development only).
# Set this to your remote server's IP if running the Python server on another machine.
# Leave unset (or set to 'localhost') when running everything on the same machine.
# VITE_SERVER_IP=192.168.1.100
